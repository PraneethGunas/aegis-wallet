# Aegis Docker — Environment Variables
# Copy to .env before running docker compose up

# Network: mainnet or testnet
BITCOIN_NETWORK=mainnet

# Ports (defaults shown, change if conflicting)
SIGNER_RPC_PORT=10012
SIGNER_REST_PORT=10013
LITD_HTTPS_PORT=8443
LND_GRPC_PORT=10009
LND_P2P_PORT=9735
LND_REST_PORT=8080
BACKEND_PORT=3001
WEB_PORT=3000

# Backend
JWT_SECRET=change-this-in-production
RP_ID=localhost
ORIGIN=http://localhost:3000
