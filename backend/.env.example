# Aegis Backend — Environment Variables
# Copy to .env and fill in your values

# LND connection (Docker container: litd)
LND_REST_HOST=https://localhost:8080
LND_CERT_PATH=./certs/tls.cert
LND_MACAROON_PATH=./certs/admin.macaroon

# litd connection (accounts, macaroon management)
LITD_HOST=https://localhost:8443

# Server
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# JWT secret (change in production)
JWT_SECRET=aegis-dev-secret

# WebAuthn
RP_ID=localhost
ORIGIN=http://localhost:3000

# Network (testnet for dev, mainnet for production)
BITCOIN_NETWORK=testnet
